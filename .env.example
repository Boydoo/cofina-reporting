# ─────────────────────────────────────────────────────────────
# COFINA Reporting — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ─────────────────────────────────────────────────────────────

# Environnement (development | production)
NODE_ENV=production

# Port du serveur (défaut : 5000)
PORT=5000

# CORS — domaine(s) autorisés en production
# Séparer par virgule si plusieurs : https://app.cofina.sn,https://reporting.cofina.sn
# Mettre * pour tout autoriser (non recommandé en prod)
CORS_ORIGIN=https://votre-domaine.com

# (Optionnel) Chemin personnalisé pour la base de données
# DB_PATH=/data/cofina.db
